# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/umoor-report?appName=Cluster0

# Auth - JWT (generate a strong random secret)
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=7d

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
BLOB_STORE_ID=your-blob-store-id

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
